rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- Global Safety Net ---
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Global Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function isValidId(id) { return id is string && id.size() <= 64 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isImmutable(field) { return incoming()[field] == existing()[field]; }
    
    function isAdmin() { 
      return isSignedIn() && (
        request.auth.token.email == 'enegocio606@gmail.com' ||
        request.auth.token.email == 'atlas@system.com'
      );
    }

    // --- Entity Validation Helpers ---
    function isValidFocoFlowItem(data) {
      return data.uid is string && data.uid == request.auth.uid &&
             data.titulo is string && data.titulo.size() <= 500 &&
             data.categoria is string && 
             data.criado_em is number;
    }

    // --- Collection Matching ---

    // FocoFlow Items (Tasks, Projects)
    match /itens_focoflow/{itemId} {
      allow get: if isSignedIn() && (existing().uid == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && (resource.data.uid == request.auth.uid || isAdmin());
      allow create: if isVerified() && isValidId(itemId) && isValidFocoFlowItem(incoming());
      allow update: if isVerified() && (existing().uid == request.auth.uid || isAdmin()) &&
                       isValidFocoFlowItem(incoming()) &&
                       isImmutable('uid') && isImmutable('criado_em');
      allow delete: if isVerified() && (existing().uid == request.auth.uid || isAdmin());
    }
  }
}
